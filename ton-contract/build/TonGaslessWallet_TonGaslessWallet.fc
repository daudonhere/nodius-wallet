;; message opcode reader utility: only binary receivers
;; Returns 32 bit message opcode, otherwise throws the "Invalid incoming message" exit code
(slice, int) ~load_opcode_internal(slice s) asm( -> 1 0) "32 LDUQ 130 THROWIFNOT";

() recv_internal(int msg_value, cell in_msg_cell, slice in_msg) impure {
    
    ;; Context
    var cs = in_msg_cell.begin_parse();
    cs~skip_bits(2);
    var msg_bounceable = cs~load_int(1);
    var msg_bounced = cs~load_int(1);
    slice msg_sender_addr = cs~load_msg_addr();
    __tact_context = (msg_bounceable, msg_sender_addr, msg_value, cs);
    __tact_context_sender = msg_sender_addr;
    
    ;; Load contract data
    var ($self'owner, $self'seqno) = $TonGaslessWallet$_contract_load();
    
    ;; Handle bounced messages
    if (msg_bounced) { return (); }
    int op = 0;
    int in_msg_length = slice_bits(in_msg);
    if (in_msg_length >= 32) {
        op = in_msg~load_uint(32);
    }
    ;; Receive Deploy message
    if (op == 0x946a98b6) {
        var $deploy'queryId = in_msg~load_uint(64);
        ($self'owner, $self'seqno)~$TonGaslessWallet$_fun_notify($DeployOk$_store_cell($DeployOk$_constructor_queryId($deploy'queryId), begin_cell()));
        $TonGaslessWallet$_contract_store(($self'owner, $self'seqno));
        return ();
    }
    
    ;; Receive empty message
    if ((op == 0) & (in_msg_length <= 32)) {
        $TonGaslessWallet$_contract_store(($self'owner, $self'seqno));
        return ();
    }
    ;; Throw if not handled
    throw(130);
}

;; message opcode reader utility: only binary receivers
;; Returns 32 bit message opcode, otherwise throws the "Invalid incoming message" exit code
(slice, int) ~load_opcode_external(slice s) asm( -> 1 0) "32 LDUQ 130 THROWIFNOT";

() recv_external(slice in_msg) impure {
    ;; Load contract data
    var ($self'owner, $self'seqno) = $TonGaslessWallet$_contract_load();
    
    var op = in_msg~load_opcode_external();
    ;; Receive SignedExecute message
    if (op == 381959420) {
        var $msg'target = in_msg~load_msg_addr();
        var $msg'value = in_msg~load_varuint16();
        var $msg'payload = in_msg~load_ref();
        var $msg'seqno = in_msg~load_uint(32);
        var $msg'signature = in_msg~load_ref();
        cell $verifyMsg = $Builder$_fun_endCell(store_uint($Builder$_fun_storeSlice($Builder$_fun_storeCoins($Builder$_fun_storeAddress($global_beginCell(), $msg'target), $msg'value), $Cell$_fun_beginParse($msg'payload)), $msg'seqno, 32));
        int $hash = $Cell$_fun_hash($verifyMsg);
        throw_unless(57400, $global_checkSignature($hash, $Cell$_fun_beginParse($msg'signature), $self'owner));
        throw_unless(32964, ($msg'seqno == $self'seqno));
        $self'seqno = $self'seqno + 1;
        $global_send($SendParameters$_constructor_to_value_body_mode($msg'target, $msg'value, $msg'payload, 67));
        $TonGaslessWallet$_contract_store(($self'owner, $self'seqno));
        return ();
    }
    
    ;; Throw if not handled
    throw(130);
}